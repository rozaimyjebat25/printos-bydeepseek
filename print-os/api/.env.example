# =====================================================================
# PRINT OS API — Environment Variables
# Copy ke Railway Variables tab
# =====================================================================

# Server
PORT=3000
NODE_ENV=production

# Supabase (PRINT OS HQ database)
SUPABASE_URL=https://ddvytkgskhegfjytwpqz.supabase.co

# Anon key — untuk client-side queries dengan user JWT
# Get from: Supabase Dashboard > Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Service role key — untuk admin operations (NEVER expose to client)
# Get from: Supabase Dashboard > Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# Optional: CORS allowed origins (comma-separated, or * for all)
ALLOWED_ORIGINS=*

# Optional: Logging level
LOG_LEVEL=info
